# Buffer Social Media Scheduler Configuration

# Required: Get your access token from https://buffer.com/developers
# Create an app → Get Access Token
BUFFER_ACCESS_TOKEN=your_access_token_here

# Optional: Default profile IDs to post to (comma-separated)
# Find these by running: python scripts/buffer_client.py list-profiles
BUFFER_DEFAULT_PROFILES=

# Wembassy Configuration (fill in after getting token):
# BUFFER_ACCESS_TOKEN=xxx
# BUFFER_DEFAULT_PROFILES=twitter_profile_id,linkedin_profile_id
